  "info": {
    "title": "API com Swagger",
    "description": "Documentação automática da API com Swagger",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "designer@letzify.com"
          },
          "password": {
            "type": "string",
            "example": "senha123"
          },
          "name": {
            "type": "string",
            "example": "Designer Letzify"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "UserDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "3f3a2c0f-92cc-4a49-a8c5-8e3de7f4f2c1"
          },
          "email": {
            "type": "string",
            "example": "designer@letzify.com"
          },
          "name": {
            "type": "string",
            "example": "Designer Letzify"
          },
          "isActive": {
            "type": "boolean",
            "example": true
          },
          "roles": {
            "type": "array",
            "example": [
              "USER"
            ],
            "items": {
              "type": "string",
              "enum": [
                "USER",
                "ADMIN"
              ]
            }
          },
          "createdAt": {
            "format": "date-time",
            "type": "string",
            "example": "2026-06-03T10:15:30.000Z"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string",
            "example": "2026-06-03T10:15:30.000Z"
          }
        },
        "required": [
          "id",
          "email",
          "isActive",
          "roles",
          "createdAt",
          "updatedAt"
        ]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "designer@letzify.com"
          },
          "password": {
            "type": "string",
            "example": "senha123"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "LoginResponseDto": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          },
          "user": {
            "$ref": "#/components/schemas/UserDto"
          }
        },
        "required": [
          "accessToken",
          "user"
        ]
      },
      "CreateProjectDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Brandbook 2026"
          },
          "description": {
            "type": "string",
            "example": "Projeto de identidade visual da campanha 2026"
          },
          "status": {
            "type": "string",
            "enum": [
              "ALIGNMENT",
              "IN_PROGRESS",
              "FINISHED"
            ],
            "example": "ALIGNMENT"
          }
        },
        "required": [
          "name"
        ]
      },
      "ProjectResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "3f3a2c0f-92cc-4a49-a8c5-8e3de7f4f2c1"
          },
          "ownerId": {
            "type": "string",
            "example": "3f3a2c0f-92cc-4a49-a8c5-8e3de7f4f2c1"
          },
          "name": {
            "type": "string",
            "example": "Brandbook 2026"
          },
          "slug": {
            "type": "string",
            "example": "brandbook-2026"
          },
          "description": {
            "type": "string",
            "example": "Projeto de identidade visual da campanha 2026"
          },
          "status": {
            "type": "string",
            "enum": [
              "ALIGNMENT",
              "IN_PROGRESS",
              "FINISHED"
            ],
            "example": "ALIGNMENT"
          },
          "createdAt": {
            "format": "date-time",
            "type": "string",
            "example": "2026-06-03T10:15:30.000Z"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string",
            "example": "2026-06-03T10:15:30.000Z"
          }
        },
        "required": [
          "id",
          "ownerId",
          "name",
          "slug",
          "status",
          "createdAt",
          "updatedAt"
        ]
      }
    }
  }
}