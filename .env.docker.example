# Copie para .env na raiz do projeto antes do deploy:
#   cp .env.docker.example .env

# Neon PostgreSQL (produção)
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# Segurança
JWT_SECRET="gere-uma-chave-longa-e-aleatoria"
JWT_EXPIRES_IN="8h"

# Domínio e HTTPS (opcional — deixe DOMAIN vazio para usar só o IP via HTTP)
DOMAIN="letzify.seudominio.com"
CERTBOT_EMAIL="seu@email.com"
# CERTBOT_STAGING=1

# URL pública do frontend (sem barra no final)
# Com domínio + HTTPS: https://letzify.seudominio.com
# Só IP: http://123.456.789.0
CORS_ORIGIN="https://letzify.seudominio.com"

# URL pública da API (com /api no final)
API_PUBLIC_URL="https://letzify.seudominio.com/api"
